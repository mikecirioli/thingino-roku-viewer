<?xml version="1.0" encoding="utf-8" ?>
<component name="HttpTask" extends="Task">
  <interface>
    <field id="request" type="assocarray" />
    <!-- request fields: url (required), method ("GET"/"POST"), body (string) -->
    <field id="response" type="string" />
    <field id="responseCode" type="integer" />
    <field id="error" type="string" />
    <field id="authType" type="string" value="basic" /> <!-- basic, thingino, none -->
    <field id="session" type="string" /> <!-- thingino_session cookie value -->
  </interface>
  <script type="text/brightscript" uri="HttpTask.brs" />
</component>
