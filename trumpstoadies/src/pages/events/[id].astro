---
import Layout from '../../layouts/Layout.astro';
import actionsData from '../../data/actions.json';
import subjectsData from '../../data/subjects.json';

export async function getStaticPaths() {
  // Get unique event IDs
  const eventIds = [...new Set(actionsData.map(a => a.eventId))];
  
  return eventIds.map(eventId => {
    const eventActions = actionsData.filter(a => a.eventId === eventId);
    const event = {
        id: eventId,
        date: eventActions[0].date,
        topic: eventActions[0].topic,
        title: eventActions[0].eventTitle,
        description: eventActions[0].description.replace(/^Voted .*? on (the Motion to Discharge )?/, '').replace(/^Voted .*? on /, ''),
        sourceUrl: eventActions[0].sourceUrl
    };
    return {
      params: { id: eventId },
      props: { event, eventActions },
    };
  });
}

const { event, eventActions } = Astro.props;

// Map subjects to actions
const fullActions = eventActions.map(action => {
    const subject = subjectsData.find(s => s.id === action.subjectId);
    return { ...action, subject };
});

const proActions = fullActions.filter(a => a.alignment === 'pro');
const antiActions = fullActions.filter(a => a.alignment === 'anti');
---

<Layout title={`${event.title} - Trump's Toadies`}>
    <div class="event-header">
        <a href="/">&larr; Back to Feed</a>
        <div class="meta">
            <span class="date">{event.date}</span>
            <span class="topic">{event.topic}</span>
        </div>
        <h2>{event.title}</h2>
        <p class="description">{event.description}</p>
        
        {event.sourceUrl && (
            <div class="source-link-container">
                <a href={event.sourceUrl} target="_blank" rel="noopener noreferrer" class="btn outline">View Official Record</a>
            </div>
        )}
    </div>

    <div class="actions-container">
        {proActions.length > 0 && (
            <div class="action-column toady-column">
                <div class="column-header pro">
                    <h3>Toady Actions</h3>
                    <span class="count">{proActions.length}</span>
                </div>
                <p class="column-desc">Votes or actions that aligned with or supported Donald Trump's position.</p>
                <div class="subject-list">
                    {proActions.map(action => (
                        <a href={`/subjects/${action.subject?.id}`} class="subject-row">
                            <div class="subject-name">
                                <strong>{action.subject?.name}</strong>
                                <span class="badge">{action.subject?.state}</span>
                                <span class={`party-dot party-${action.subject?.party?.toLowerCase()}`} title={action.subject?.party}></span>
                            </div>
                            <div class="vote-text">{action.title.split(' on ')[0]}</div>
                        </a>
                    ))}
                </div>
            </div>
        )}

        {antiActions.length > 0 && (
            <div class="action-column anti-column">
                <div class="column-header anti">
                    <h3>Opposing Actions</h3>
                    <span class="count">{antiActions.length}</span>
                </div>
                <p class="column-desc">Votes or actions that opposed Donald Trump's position.</p>
                <div class="subject-list">
                    {antiActions.map(action => (
                        <a href={`/subjects/${action.subject?.id}`} class="subject-row">
                            <div class="subject-name">
                                <strong>{action.subject?.name}</strong>
                                <span class="badge">{action.subject?.state}</span>
                                <span class={`party-dot party-${action.subject?.party?.toLowerCase()}`} title={action.subject?.party}></span>
                            </div>
                            <div class="vote-text">{action.title.split(' on ')[0]}</div>
                        </a>
                    ))}
                </div>
            </div>
        )}
    </div>
</Layout>

<style>
    .event-header {
        background: var(--color-card);
        border: 1px solid var(--color-border);
        border-top: 4px solid var(--color-text);
        padding: 2rem;
        border-radius: 8px;
        margin-bottom: 2rem;
    }
    .event-header > a {
        display: inline-block;
        margin-bottom: 1.5rem;
        color: var(--color-muted);
    }
    .meta {
        display: flex;
        gap: 1rem;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
        color: var(--color-muted);
    }
    .topic {
        font-weight: bold;
        color: var(--color-text);
    }
    .event-header h2 {
        font-size: 2.5rem;
        line-height: 1.2;
        margin-bottom: 1rem;
    }
    .description {
        font-size: 1.25rem;
        margin-bottom: 1.5rem;
        color: #444;
    }
    .source-link-container {
        padding-top: 1rem;
        border-top: 1px solid var(--color-border);
    }
    .btn.outline {
        border: 2px solid var(--color-text);
        color: var(--color-text);
        background: transparent;
        padding: 0.5rem 1rem;
        border-radius: 4px;
        font-weight: bold;
        display: inline-block;
    }
    .btn.outline:hover {
        background: var(--color-text);
        color: #fff;
        text-decoration: none;
    }

    .actions-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }
    @media (max-width: 768px) {
        .actions-container {
            grid-template-columns: 1fr;
        }
    }
    
    .action-column {
        background: var(--color-card);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        overflow: hidden;
    }
    .column-header {
        padding: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--color-border);
    }
    .column-header h3 {
        margin: 0;
        font-size: 1.5rem;
    }
    .column-header.pro {
        background: #fdf2f2;
        border-bottom-color: #f5b7b1;
    }
    .column-header.pro h3, .column-header.pro .count {
        color: #c0392b;
    }
    .column-header.anti {
        background: #ebf5fb;
        border-bottom-color: #a9cce3;
    }
    .column-header.anti h3, .column-header.anti .count {
        color: #2980b9;
    }
    .count {
        font-size: 1.5rem;
        font-weight: bold;
    }
    .column-desc {
        padding: 1rem 1.5rem;
        font-size: 0.95rem;
        color: var(--color-muted);
        border-bottom: 1px solid var(--color-border);
        background: #fafafa;
    }
    
    .subject-list {
        max-height: 600px;
        overflow-y: auto;
    }
    .subject-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #eee;
        color: var(--color-text);
        text-decoration: none;
        transition: background 0.1s;
    }
    .subject-row:hover {
        background: #f5f5f5;
        text-decoration: none;
    }
    .subject-row:last-child {
        border-bottom: none;
    }
    .subject-name {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .badge {
        font-size: 0.7rem;
        background: #eee;
        color: #666;
        padding: 0.1rem 0.4rem;
        border-radius: 4px;
        font-weight: bold;
    }
    .party-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
    }
    .party-republican { background: #e74c3c; }
    .party-democrat { background: #3498db; }
    .party-independent { background: #95a5a6; }
    
    .vote-text {
        font-weight: 500;
        font-size: 0.9rem;
    }
</style>