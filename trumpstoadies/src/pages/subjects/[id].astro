---
import Layout from '../../layouts/Layout.astro';
import subjectsData from '../../data/subjects.json';
import actionsData from '../../data/actions.json';

export async function getStaticPaths() {
  return subjectsData.map(subject => ({
    params: { id: subject.id },
    props: { subject },
  }));
}

const { subject } = Astro.props;

const subjectActions = actionsData
    .filter(a => a.subjectId === subject.id)
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title={`${subject.name} - Trump's Toadies`}>
    <div class="profile-header">
        <a href="/">&larr; Back to Feed</a>
        <div class="title-row">
            <h2>{subject.name}</h2>
            <span class="badge">{subject.type}</span>
            {subject.state && <span class="badge state-badge">{subject.state}</span>}
        </div>
        <p class="description">{subject.description}</p>
        <div class="stats">
            <strong>{subjectActions.length}</strong> Actions Tracked
        </div>
    </div>

    <h3 class="section-title">Tracked Actions</h3>
    
    <div class="action-feed">
		{subjectActions.map(action => (
			<article class="action-card">
				<div class="card-header">
					<span class="date">{action.date}</span>
					<span class="topic">{action.topic}</span>
				</div>
				<h4>{action.title}</h4>
				<p class="description">{action.description}</p>
				<div class="card-footer">
					{action.sourceUrl && <a href={action.sourceUrl} target="_blank" rel="noopener noreferrer" class="source-link">Source &rarr;</a>}
				</div>
			</article>
		))}
        {subjectActions.length === 0 && <p>No actions tracked yet.</p>}
	</div>
</Layout>

<style>
    .profile-header {
        background: var(--color-card);
        border: 1px solid var(--color-border);
        padding: 2rem;
        border-radius: 8px;
        margin-bottom: 2rem;
    }
    .profile-header > a {
        display: inline-block;
        margin-bottom: 1rem;
        color: var(--color-muted);
    }
    .title-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }
    .title-row h2 {
        font-size: 2.5rem;
        margin: 0;
    }
    .badge {
        font-size: 0.875rem;
        background: #2c3e50;
        color: #fff;
        padding: 0.3rem 0.6rem;
        border-radius: 4px;
        font-weight: bold;
    }
    .state-badge {
        background: #7f8c8d;
    }
    .description {
        font-size: 1.125rem;
        margin-bottom: 1.5rem;
    }
    .stats {
        padding-top: 1rem;
        border-top: 1px solid var(--color-border);
        color: var(--color-muted);
    }
    .stats strong {
        color: var(--color-accent);
        font-size: 1.5rem;
    }
    .section-title {
        margin-bottom: 1rem;
        font-size: 1.5rem;
        border-bottom: 2px solid var(--color-border);
        padding-bottom: 0.5rem;
    }
    .action-feed {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    .action-card {
        background: var(--color-card);
        border: 1px solid var(--color-border);
        border-left: 4px solid var(--color-accent);
        border-radius: 8px;
        padding: 1.5rem;
    }
    .card-header {
        display: flex;
        justify-content: space-between;
        font-size: 0.875rem;
        color: var(--color-muted);
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .topic {
        background: #eee;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-weight: bold;
        color: var(--color-text);
    }
    .action-card h4 {
        font-size: 1.25rem;
        margin-bottom: 0.5rem;
    }
    .description {
        margin-bottom: 1.5rem;
    }
</style>