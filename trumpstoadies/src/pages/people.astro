---
import Layout from '../layouts/Layout.astro';
import subjectsData from '../data/subjects.json';
import actionsData from '../data/actions.json';

// Calculate toady actions for each subject
const subjectsWithStats = subjectsData.map(subject => {
    const subjectActions = actionsData.filter(a => a.subjectId === subject.id);
    const toadyActions = subjectActions.filter(a => a.alignment === 'pro').length;
    return { ...subject, toadyActions, totalActions: subjectActions.length };
});

const byType = subjectsWithStats.reduce((acc, subject) => {
    if (!acc[subject.type]) acc[subject.type] = [];
    acc[subject.type].push(subject);
    return acc;
}, {} as Record<string, typeof subjectsWithStats>);

const types = Object.keys(byType);
---

<Layout title="People & Businesses - Trump's Toadies">
    <div class="header-section">
		<h2>The Toadies Directory</h2>
		<p class="subtitle">A directory of individuals and corporations and their alignment with Donald Trump.</p>
	</div>

    <div class="directory-controls">
        <input type="text" id="directorySearch" placeholder="Search by name, state, or party..." />
        
        <label class="toggle-switch">
            <input type="checkbox" id="toadyFilter" checked>
            <span class="slider"></span>
            <span class="label-text">Only show active Toadies</span>
        </label>
    </div>

    {Object.entries(byType).map(([type, subjects]) => (
        <div class="type-group" data-type={type}>
            <h3 class="type-title">{type}s <span class="count" data-group-count>({subjects.length})</span></h3>
            <div class="subject-grid">
                {subjects.map(subject => {
                    const isToady = subject.toadyActions > 0 || (subject.type !== 'Representative' && subject.type !== 'Senator');
                    return (
                    <a href={`/subjects/${subject.id}`} 
                       class="subject-card" 
                       data-is-toady={isToady ? 'true' : 'false'}
                       data-search={`${subject.name} ${subject.state || ''} ${subject.party || ''}`.toLowerCase()}>
                        <div class="subject-info">
                            <h4>{subject.name}</h4>
                            <div class="badges">
                                {subject.state && <span class="badge state-badge">{subject.state}</span>}
                                {subject.party && (
                                    <span class={`badge party-badge party-${subject.party.toLowerCase()}`}>
                                        {subject.party}
                                    </span>
                                )}
                            </div>
                        </div>
                        {subject.toadyActions > 0 && (
                            <div class="action-count">
                                <strong>{subject.toadyActions}</strong> tracked action{subject.toadyActions !== 1 ? 's' : ''}
                            </div>
                        )}
                    </a>
                )})}
            </div>
        </div>
    ))}
</Layout>

<script>
    const searchInput = document.getElementById('directorySearch') as HTMLInputElement;
    const toadyFilter = document.getElementById('toadyFilter') as HTMLInputElement;
    const cards = document.querySelectorAll('.subject-card');
    const typeGroups = document.querySelectorAll('.type-group');

    function filterDirectory() {
        const term = searchInput.value.toLowerCase();
        const showOnlyToadies = toadyFilter.checked;
        
        cards.forEach((card: any) => {
            const matchesSearch = card.dataset.search.includes(term);
            const matchesToady = showOnlyToadies ? card.dataset.isToady === 'true' : true;
            
            if (matchesSearch && matchesToady) {
                card.style.display = 'flex';
            } else {
                card.style.display = 'none';
            }
        });

        // Hide type headers if no cards are visible and update counts
        typeGroups.forEach((group: any) => {
            const visibleCards = group.querySelectorAll('.subject-card[style="display: flex;"]');
            const hasVisible = visibleCards.length > 0;
            group.style.display = hasVisible ? 'block' : 'none';
            
            const countSpan = group.querySelector('[data-group-count]');
            if (countSpan) {
                countSpan.textContent = `(${visibleCards.length})`;
            }
        });
    }

    searchInput.addEventListener('input', filterDirectory);
    toadyFilter.addEventListener('change', filterDirectory);
    
    // Run initially to apply default filter
    filterDirectory();
</script>

<style>
    .header-section {
        margin-bottom: 2rem;
    }
    .header-section h2 {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }
    .subtitle {
        color: var(--color-muted);
        font-size: 1.1rem;
    }
    .directory-controls {
        margin-bottom: 2rem;
        position: sticky;
        top: 1rem;
        z-index: 10;
        background: var(--color-bg);
        padding: 1rem 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .directory-controls input[type="text"] {
        width: 100%;
        padding: 1rem;
        font-size: 1.1rem;
        border: 2px solid var(--color-border);
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    
    /* Toggle Switch */
    .toggle-switch {
        display: flex;
        align-items: center;
        cursor: pointer;
        gap: 0.5rem;
        font-weight: 500;
        color: #c0392b;
    }
    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
        position: absolute;
    }
    .slider {
        position: relative;
        display: inline-block;
        width: 40px;
        height: 20px;
        background-color: #ccc;
        border-radius: 20px;
        transition: .4s;
    }
    .slider:before {
        position: absolute;
        content: "";
        height: 16px;
        width: 16px;
        left: 2px;
        bottom: 2px;
        background-color: white;
        border-radius: 50%;
        transition: .4s;
    }
    .toggle-switch input:checked + .slider {
        background-color: #c0392b;
    }
    .toggle-switch input:checked + .slider:before {
        transform: translateX(20px);
    }

    .type-group {
        margin-bottom: 3rem;
    }
    .type-title {
        font-size: 1.5rem;
        border-bottom: 2px solid var(--color-border);
        padding-bottom: 0.5rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .count {
        color: var(--color-muted);
        font-size: 1.1rem;
        font-weight: normal;
    }
    .subject-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1rem;
    }
    .subject-card {
        background: var(--color-card);
        border: 1px solid var(--color-border);
        padding: 1rem;
        border-radius: 8px;
        color: var(--color-text);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: transform 0.1s, border-color 0.2s;
    }
    .subject-card:hover {
        border-color: var(--color-accent);
        text-decoration: none;
        transform: translateY(-2px);
    }
    .subject-info h4 {
        margin: 0 0 0.75rem 0;
        font-size: 1.1rem;
        line-height: 1.2;
    }
    .badges {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .badge {
        font-size: 0.7rem;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-weight: bold;
        text-transform: uppercase;
    }
    .state-badge {
        background: #eee;
        color: #444;
        border: 1px solid #ddd;
    }
    /* Party Colors */
    .party-republican {
        background: #e74c3c;
        color: #fff;
    }
    .party-democrat {
        background: #3498db;
        color: #fff;
    }
    .party-independent {
        background: #95a5a6;
        color: #fff;
    }
    .party-badge:not(.party-republican):not(.party-democrat):not(.party-independent) {
        background: #2c3e50;
        color: #fff;
    }
    .action-count {
        margin-top: 1rem;
        font-size: 0.85rem;
        color: #c0392b;
        background: #fdf2f2;
        padding: 0.3rem 0.5rem;
        border-radius: 4px;
        text-align: center;
        border: 1px solid #f5b7b1;
    }
</style>