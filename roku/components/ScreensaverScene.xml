<component name="ScreensaverScene" extends="Scene">
  <children>
    <!-- Black background -->
    <Rectangle id="bg" width="1920" height="1080" color="#000000" />

    <!-- Double-buffered photo layers -->
    <Poster id="photoA" width="1920" height="1080"
            translation="[0,0]" loadDisplayMode="scaleToFit" opacity="0.0" />
    <Poster id="photoB" width="1920" height="1080"
            translation="[0,0]" loadDisplayMode="scaleToFit" opacity="0.0" />

    <!-- Floating overlay (bounces for anti-burn-in) -->
    <Group id="overlay" translation="[100,100]">
      <Rectangle id="overlayBg" width="420" height="160"
                 color="#000000E6" cornerRadius="14" />
      <LayoutGroup id="overlayContent" translation="[24,16]"
                   layoutDirection="vert" itemSpacings="[2]">
        <Label id="clock" text=""
               color="#FFFFFF" width="372" horizAlign="right" />
        <Label id="dateLabel" text=""
               color="#FFFF00" width="372" horizAlign="right" />
        <Rectangle width="372" height="1" color="#FFFFFF99" />
        <Label id="dataChip" text=""
               color="#00FF00" width="372" horizAlign="right">
          <Font role="font" uri="pkg:/fonts/DejaVuSans.ttf" size="14" />
        </Label>
      </LayoutGroup>
    </Group>

    <!-- Crossfade animations -->
    <Animation id="fadeInA" duration="1.5" repeat="false" easeFunction="inOutCubic">
      <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[0.0, 1.0]"
                              fieldToInterp="photoA.opacity" />
    </Animation>
    <Animation id="fadeOutA" duration="1.5" repeat="false" easeFunction="inOutCubic">
      <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[1.0, 0.0]"
                              fieldToInterp="photoA.opacity" />
    </Animation>
    <Animation id="fadeInB" duration="1.5" repeat="false" easeFunction="inOutCubic">
      <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[0.0, 1.0]"
                              fieldToInterp="photoB.opacity" />
    </Animation>
    <Animation id="fadeOutB" duration="1.5" repeat="false" easeFunction="inOutCubic">
      <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[1.0, 0.0]"
                              fieldToInterp="photoB.opacity" />
    </Animation>

    <!-- Timers -->
    <Timer id="photoTimer" repeat="true" duration="30" />
    <Timer id="clockTimer" repeat="true" duration="30" />
    <Timer id="dataTimer" repeat="true" duration="120" />
    <Timer id="bounceTimer" repeat="true" duration="1" />
  </children>

  <script type="text/brightscript" uri="ScreensaverScene.brs" />
</component>
