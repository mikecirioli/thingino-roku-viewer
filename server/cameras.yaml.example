# 3 Bad Dogs — Camera Configuration
#
# Copy this file to cameras.yaml and edit for your setup.
# Mount into the container at /config/cameras.yaml (or set CAMERAS_FILE env var).

cameras:
  # Thingino camera with snapshot URL and session auth
  front-door:
    snapshot: http://192.168.1.55/x/ch0.jpg
    auth:
      type: a_secure_password
      username: admin
      password: front-door

  # Camera with snapshot, HLS stream, and PTZ (ONVIF)
  # Roku app uses HLS for live video, D-pad for PTZ in fullscreen
  living-room:
    snapshot: http://192.168.1.106/x/ch0.jpg
    stream: http://192.168.1.207:1984/api/stream.m3u8?src=living-room_main
    auth:
      type: a_secure_password
      username: admin
      password: password456
    onvif:
      host: 192.168.1.106
      port: 80
      username: a_secure_password
      password: a_secure_password

  # Stream-only camera (no snapshot URL)
  # Server will use ffmpeg to extract frames for screensaver
  camera-3:
    stream: http://192.168.1.207:1984/api/stream.m3u8?src=camera-3_main
    stream_type: hls

  # Basic auth camera (non-a_secure_password)
  # garage:
  #   snapshot: http://192.168.1.100/snapshot.jpg
  #   auth:
  #     type: basic
  #     username: admin
  #     password: secret

  # No-auth camera (public snapshot URL)
  # weathercam:
  #   snapshot: http://192.168.1.200/image.jpg
